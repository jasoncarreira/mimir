# mimir environment variables
#
# Copy this file to <agent-home>/.env (NOT to the repo root .env, which
# `mimir setup` will create with auto-generated MIMIR_API_KEY etc.).
# Comment out or omit anything you're not using.

# ─── LLM authentication ───────────────────────────────────────────────
# Pick ONE of these three paths.

# Path A — Anthropic API key (pay-per-token):
ANTHROPIC_API_KEY=

# Path B — Anthropic Max plan via OAuth (run `claude setup-token` to mint):
# Leave ANTHROPIC_API_KEY blank when using this path.
ANTHROPIC_AUTH_TOKEN=

# Path C — Gateway (LiteLLM, OpenRouter, etc.). Set both URL and token.
ANTHROPIC_BASE_URL=
# ANTHROPIC_AUTH_TOKEN= shared with Path B above

# Reader model. Default: claude-opus-4-7. Common alternatives:
#   claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODEL=
MIMIR_MODEL=

# Reasoning effort. Default: high. Other: low | medium.
MIMIR_EFFORT=

# ─── Embeddings + saga LLM (optional, recommended) ───────────────────
# Saga uses OpenAI for embeddings + consolidation by default. Without
# OPENAI_API_KEY, saga falls back to local fastembed — slower but free.
OPENAI_API_KEY=

# ─── Mimir runtime ────────────────────────────────────────────────────
# Agent home — where memory/, state/, .mimir/, scheduler.yaml live.
# Default: cwd. Override per-run via `mimir run --home <path>`.
MIMIR_HOME=

# API key for the mimir HTTP server (auto-generated by `mimir setup`).
MIMIR_API_KEY=

# Operator alert channel — bridge channel id where the agent sends
# high-priority signals via the alert skill (e.g. `dm-discord-99`).
MIMIR_OPERATOR_ALERT_CHANNEL=

# Cost limits (USD per hour). 0 disables the absolute check.
MIMIR_COST_HOURLY_LIMIT_USD=
MIMIR_COST_RATE_SPIKE_RATIO=
MIMIR_COST_ALERT_COOLDOWN_MINUTES=

# Algedonic feedback block (recent pain/pleasure signals in turn prompt).
MIMIR_FEEDBACK_WINDOW_HOURS=24
MIMIR_FEEDBACK_LIMIT=5

# Recent activity block sources allowlist. Default:
#   slack,discord,bluesky,web,stdin
MIMIR_RECENT_SOURCES=

# Heartbeat / scheduler crons (override defaults if needed). Cron syntax.
# Default heartbeat: hourly. Default reflection: Sun 06:00 UTC.
# These live in scheduler.yaml; only the saga + introspection crons are
# environment-driven.
MIMIR_SAGA_CONSOLIDATE_CRON=
MIMIR_INTROSPECTION_REPORT_CRON=
MIMIR_INTROSPECTION_REPORT_DAYS=
MIMIR_INTROSPECTION_HEALTH_THRESHOLD=
MIMIR_INTROSPECTION_EMIT_ALGEDONIC=

# Saga session idle timeout (minutes). After this much silence on a
# channel, saga rolls a session boundary atom.
MIMIR_SAGA_SESSION_IDLE_MINUTES=

# Saga retrieval — minimum confidence tier for the pre-message hook.
# Empty = use saga's [retrieval] default. Override: low | medium | high.
MIMIR_SAGA_PRE_MSG_MIN_TIER=

# Send-message loop detector. The hook fires when the agent's last N
# outputs are too similar; soft warns before hard-stopping.
MIMIR_SEND_LOOP_SOFT_LIMIT=
MIMIR_SEND_LOOP_HARD_LIMIT=
MIMIR_SEND_LOOP_SIMILARITY=

# Per-turn tool-call budget (warning event when exceeded; not enforced).
MIMIR_TOOL_CALL_BUDGET=

# Log retention caps.
MIMIR_MAX_TURNS=
MIMIR_MAX_EVENTS=
MIMIR_TURNS_ARCHIVE_DIR=

# ─── Bridges (each is independent) ────────────────────────────────────
# Discord: bot token + intents enabled in the developer portal.
DISCORD_TOKEN=

# Slack: socket-mode app. Need both tokens.
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Bluesky: handle (e.g. `me.bsky.social`) + app password (NOT main pw).
BSKY_HANDLE=
BSKY_APP_PASSWORD=

# ─── Saga (memory backend) ────────────────────────────────────────────
# Default: in-process saga via the `saga` Python package. Set these only
# if you're running saga as a separate HTTP server.
SAGA_ENDPOINT=
SAGA_API_KEY=

# ─── Misc ─────────────────────────────────────────────────────────────
MIMIR_CAPTURE_RATE_LIMITS=true
MIMIR_USAGE_BLOCK=true
MIMIR_CROSS_PLATFORM_PULL=true
MIMIR_EMBED_MODEL=BAAI/bge-small-en-v1.5
MIMIR_PROMPTS_DIR=
CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS=
ANTHROPIC_CUSTOM_MODEL_OPTION=
