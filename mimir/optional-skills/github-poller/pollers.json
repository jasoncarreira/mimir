{
  "pollers": [
    {
      "name": "github-activity",
      "command": "python3 poller.py",
      "cron": "*/15 * * * *",
      "batch_size": 5,
      "authority": {
        "profile": "github",
        "tier": "code-execution",
        "capabilities": ["worklink_run", "write_file", "edit_file", "shell_exec", "send_message", "operator_alert"],
        "scoped_roots": ["state"]
      },
      "trust_source": "github",
      "env_required": [
        "GITHUB_REPOS"
      ],
      "pass_env": [
        "GITHUB_TOKEN",
        "GITHUB_REPOS",
        "MIMIR_GITHUB_SELF_LOGIN",
        "MIMIR_HOME",
        "MIMIR_GITHUB_PRELOAD_REVIEW_SKILL",
        "MIMIR_GITHUB_REVIEW_SKILL_PATH"
      ]
    }
  ]
}
