{
  "pollers": [
    {
      "name": "github-ci-watch",
      "command": "python3 poller.py",
      "cron": "*/15 * * * *",
      "authority": {
        "profile": "github",
        "tier": "code-execution",
        "capabilities": ["worklink_run", "write_file", "edit_file", "shell_exec", "send_message", "operator_alert"],
        "scoped_roots": ["state"]
      },
      "pass_env": [
        "GITHUB_TOKEN",
        "GITHUB_REPOS"
      ]
    }
  ]
}
