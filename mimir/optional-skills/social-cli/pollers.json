{
  "pollers": [
    {
      "name": "social-cli-notifications",
      "command": "python3 poller.py",
      "cron": "*/15 * * * *",
      "batch_size": 3,
      "authority": {
        "profile": "research",
        "tier": "scoped-with-provenance",
        "capabilities": ["memory_store", "saga_feedback", "saga_mark_contributions", "write_file", "edit_file", "send_message"],
        "scoped_roots": ["state"]
      },
      "pass_env": [
        "MIMIR_SOCIAL_PLATFORMS",
        "MIMIR_SOCIAL_LIMIT",
        "MIMIR_SOCIAL_USERS_DIR",
        "SOCIAL_CLI_BIN",
        "ATPROTO_HANDLE",
        "ATPROTO_APP_PASSWORD"
      ]
    },
    {
      "name": "social-cli-feed",
      "command": "python3 feed_poller.py",
      "cron": "0 */2 * * *",
      "batch_size": 10,
      "authority": {
        "profile": "research",
        "tier": "scoped-with-provenance",
        "capabilities": ["memory_store", "saga_feedback", "saga_mark_contributions", "write_file", "edit_file", "send_message"],
        "scoped_roots": ["state"]
      },
      "pass_env": [
        "MIMIR_SOCIAL_PLATFORMS",
        "MIMIR_SOCIAL_FEED_LIMIT",
        "SOCIAL_CLI_BIN",
        "ATPROTO_HANDLE",
        "ATPROTO_APP_PASSWORD"
      ]
    }
  ]
}
