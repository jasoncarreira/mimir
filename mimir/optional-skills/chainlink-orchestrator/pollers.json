{
  "pollers": [
    {
      "name": "worklink-ready-queue",
      "command": "python3 poller.py",
      "cron": "*/10 * * * *",
      "priority": "normal",
      "env_required": [
        "WORKLINK_REPO"
      ],
      "pass_env": [
        "MIMIR_HOME",
        "MIMIR_SOURCE_DIR",
        "CHAINLINK_BIN",
        "WORKLINK_RUN_BIN",
        "WORKLINK_REPO",
        "WORKLINK_MAX_CONCURRENT",
        "MIMIR_FACTORY_EPICS_ENABLED",
        "GITHUB_TOKEN",
        "GH_TOKEN",
        "OPENAI_API_KEY",
        "ANTHROPIC_API_KEY",
        "MINIMAX_API_KEY",
        "OPENROUTER_API_KEY",
        "GROQ_API_KEY",
        "GEMINI_API_KEY",
        "GOOGLE_API_KEY",
        "VOYAGE_API_KEY"
      ]
    }
  ]
}
